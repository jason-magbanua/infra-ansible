[all:vars]
ansible_user=infra
ansible_ssh_private_key_file=~/.ssh/id_rsa_ansible
ansible_python_interpreter=/usr/bin/python3

[proxmox]
pve1 ansible_host=10.10.200.8 ansible_user=root ansible_ssh_private_key_file=~/.ssh/root-sshkey.rsa


[proxmox_vms]
wp-host1 ansible_host=10.10.200.11
wp-host2 ansible_host=10.10.200.13


[proxmox_containers]
jump-host ansible_host=10.10.200.30 ansible_user=root
nginx ansible_host=10.10.200.29 ansible_user=root

