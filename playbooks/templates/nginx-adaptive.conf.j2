user www-data;
worker_processes {{ nginx_worker_processes }};
pid /run/nginx.pid;

events {
    worker_connections 1024;
    use epoll;
    multi_accept on;
}

http {

    ##
    # Basic Performance
    ##
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;

    keepalive_timeout 15;
    keepalive_requests 500;

    types_hash_max_size 2048;
    server_tokens off;

    ##
    # Buffer tuning
    ##
    client_body_buffer_size 10K;
    client_header_buffer_size 1k;
    large_client_header_buffers 2 1k;

    ##
    # Logging
    ##
    access_log off;
    error_log /var/log/nginx/error.log warn;

    ##
    # Compression
    ##
    gzip on;
    gzip_comp_level 3;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        application/json
        application/javascript
        application/xml
        text/xml
        image/svg+xml;

    ##
    # Rate limiting
    ##
    limit_req_zone $binary_remote_addr zone=wp:10m rate=5r/s;

    ##
    # FastCGI cache (scaled with RAM)
    ##
    fastcgi_cache_path /var/cache/nginx
        levels=1:2
        keys_zone=WORDPRESS:{{ (ansible_memtotal_mb / 20) | int }}m
        inactive=30m
        max_size={{ (ansible_memtotal_mb / 2) | int }}m;

    fastcgi_cache_key "$scheme$request_method$host$request_uri";

    ##
    # Includes
    ##
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
