# Managed by Ansible — do not edit by hand
# Provisioned datasources are read-only in the Grafana UI. This is expected.
apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    uid: prometheus
    url: http://{{ prometheus_ip }}:{{ prometheus_port }}
    isDefault: true
    access: proxy
    editable: false

  - name: Loki
    type: loki
    uid: loki
    url: http://{{ loki_ip }}:{{ loki_port }}
    access: proxy
    editable: false

  # Alertmanager — uncomment when the Alertmanager LXC ({{ alertmanager_ip }}:{{ alertmanager_port }}) is deployed
  # - name: Alertmanager
