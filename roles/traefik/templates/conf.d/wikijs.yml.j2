# Managed by Ansible — do not edit by hand
# Hot-reloaded by Traefik via file provider watch: true
http:
  routers:
    wikijs:
      rule: "Host(`wiki.{{ traefik_domain }}`)"
      entryPoints:
        - websecure
      service: wikijs
      tls:
        certResolver: cloudflare
        domains:
          - main: "{{ traefik_domain }}"
            sans:
              - "*.{{ traefik_domain }}"

  services:
    wikijs:
      loadBalancer:
        servers:
          - url: "http://{{ wikijs_ip }}:{{ wikijs_port }}"
