# Managed by Ansible — do not edit by hand
# Hot-reloaded by Traefik via file provider watch: true
http:
  routers:
    authentik:
      rule: "Host(`authentik.{{ traefik_domain }}`)"
      entryPoints:
        - websecure
      service: authentik
      tls:
        certResolver: cloudflare
        domains:
          - main: "{{ traefik_domain }}"
            sans:
              - "*.{{ traefik_domain }}"

  services:
    authentik:
      loadBalancer:
        servers:
          - url: "http://{{ authentik_ip }}:{{ authentik_port }}"
