// Managed by Ansible — do not edit by hand

// -------------------------------------------------------
// Log collection — local systemd journal
// -------------------------------------------------------
loki.source.journal "local" {
  forward_to    = [loki.write.default.receiver]
  relabel_rules = loki.relabel.journal.rules
  labels = {
    job = "systemd-journal",
  }
}

loki.relabel "journal" {
  forward_to = []

  rule {
    source_labels = ["__journal__hostname"]
    target_label  = "host"
  }
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }
}

// -------------------------------------------------------
// Log push receiver — accepts Loki-compatible pushes
// from other hosts on port {{ alloy_loki_push_port }}
// -------------------------------------------------------
loki.source.api "push" {
  http {
    listen_address = "0.0.0.0"
    listen_port    = {{ alloy_loki_push_port }}
  }
  forward_to = [loki.write.default.receiver]
}

// -------------------------------------------------------
// Write to Loki
// -------------------------------------------------------
loki.write "default" {
  endpoint {
    url = "http://{{ loki_ip }}:{{ loki_port }}/loki/api/v1/push"
  }
}
